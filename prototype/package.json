{
  "name": "my-success-story-prototype",
  "version": "0.1.0",
  "description": "First iteration of My Success Story",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "build": "node -e \"const fs=require('fs');const sw=fs.readFileSync('sw.js','utf8');fs.writeFileSync('sw.js',sw.replace('__BUILD_TIMESTAMP__','v'+Date.now()))\"",
    "_old_dev": "node --watch server.js",
    "dev": "nodemon server.js",
    "test": "cross-env MOCK_MODE=true node --watch server.js",
    "test-mode": "cross-env TEST_MODE=true node server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@supabase/supabase-js": "^2.97.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "openai": "^4.104.0",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
